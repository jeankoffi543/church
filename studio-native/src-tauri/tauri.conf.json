{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Studio Native",
  "version": "0.1.0",
  "identifier": "ci.churchapp.studionative",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ui dev",
    "beforeBuildCommand": "pnpm --dir ui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Studio Native",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Video",
    "publisher": "ChurchApp CI",
    "homepage": "https://github.com/jeankoffi543/church",
    "shortDescription": "Régie vidéo native pour l'église",
    "longDescription": "Studio Native — régie de production vidéo native : capture écran/caméra, overlays (texte/verset/chant), mixage audio, enregistrement local et diffusion Facebook Live (RTMPS direct). Le portage GStreamer/Rust du studio web, en application de bureau.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libgstreamer1.0-0",
          "libgstreamer-plugins-base1.0-0",
          "gstreamer1.0-plugins-good"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
