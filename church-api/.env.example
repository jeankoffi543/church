APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=church_api
DB_USERNAME=root
DB_PASSWORD=

# --- Multi-tenant: central ("landlord") DB (CHR-133) ---
# Orchestration only (tenants/domains/plans/subscriptions/studio keys).
TENANCY_CENTRAL_CONNECTION=central
CENTRAL_DB_DRIVER=mysql
CENTRAL_DB_HOST=127.0.0.1
CENTRAL_DB_PORT=3306
CENTRAL_DB_DATABASE=church_central
CENTRAL_DB_USERNAME=root
CENTRAL_DB_PASSWORD=
# Comma-separated hosts served by the central app (marketing site / platform).
CENTRAL_DOMAINS=churchapp.io,app.churchapp.io

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Realtime is core (live chat/reactions, scripture overlay, back-office notifs),
# so the default broadcaster is Reverb — see the REVERB_* block below.
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Async work runs on Redis (CHR-159): higher throughput than the DB driver and
# the target for Horizon (CHR-160). Jobs are split by workload into named queues
# (default / mail / media / push / broadcast, see App\Enums\QueueName) drained by
# ONE global worker fleet — never per-tenant; stancl restores the tenant per job.
# See deploy/supervisor/church-api.conf for the worker/queue priority split.
QUEUE_CONNECTION=redis
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default

# Multitenancy: stancl's CacheTenancyBootstrapper scopes each tenant's cache with
# a per-tenant TAG, so the store MUST support tagging (redis / memcached / array).
# `database` and `file` do NOT support tags → in tenant context every cache call
# throws "This cache store does not support tagging".
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Laravel Reverb (WebSockets) — CHR-158 -----------------------------------
# One SHARED Reverb server for every tenant; isolation is by channel name
# (`tenant.{id}.*`, CHR-155/156), not by server. Generate app credentials with
# `php artisan reverb:install` (or set them here). The *_KEY is public (shipped
# to the browser); the *_SECRET must stay server-side.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Client-facing endpoint the browser/Echo connects to. In PRODUCTION terminate
# TLS at the edge (Caddy/nginx, see deploy/reverb/) and expose wss:// on 443:
#   REVERB_HOST=ws.churchapp.io   REVERB_PORT=443   REVERB_SCHEME=https
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Where the `reverb:start` process actually binds (behind the TLS proxy in prod).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Horizontal scaling: with more than one app/Reverb node, broadcasts are fanned
# out over Redis pub/sub so every socket — on any node — receives them. Leave
# false for a single node (local/dev); set true in production (uses the REDIS_*
# connection above). See config/reverb.php `servers.reverb.scaling`.
REVERB_SCALING_ENABLED=false

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
RTMP_PUBLISH_KEY=
